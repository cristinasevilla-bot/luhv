var express = require('express');
var webpush = require('web-push');
var router = express.Router();
var engine = require('./nudge-engine');
var supabaseLib = require('@supabase/supabase-js');

var supabase = supabaseLib.createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SERVICE_KEY
);

webpush.setVapidDetails(
  process.env.VAPID_MAILTO,
  process.env.VAPID_PUBLIC_KEY,
  process.env.VAPID_PRIVATE_KEY
);

router.post('/subscribe', async function(req, res) {
  var subscription = req.body.subscription;
  var userId = req.body.userId;
  var peakHour = req.body.peakHour;
  if (!subscription || !userId) return res.status(400).json({ error: 'Missing data' });
  var result = await supabase.from('push_subscriptions').upsert({
    user_id: userId,
    endpoint: subscription.endpoint,
    keys: subscription.keys,
    peak_hour: peakHour || 'Evening (5-9pm)',
    updated_at: new Date().toISOString()
  }, { onConflict: 'user_id' });
  if (result.error) return res.status(500).json({ error: result.error.message });
  res.json({ success: true });
});

router.post('/unsubscribe', async function(req, res) {
  var userId = req.body.userId;
  await supabase.from('push_subscriptions').delete().eq('user_id', userId);
  res.json({ success: true });
});

router.post('/send-nudge', async function(req, res) {
  if (req.headers['x-cron-secret'] !== process.env.CRON_SECRET) {
    return res.status(401).json({ error: 'Unauthorized' });
  }
  var nudgeType = req.body.nudgeType;
  if (!nudgeType) return res.status(400).json({ error: 'nudgeType required' });
  var results = await sendNudgesForType(nudgeType);
  res.json(results);
});

async function sendNudgesForType(nudgeType) {
  var today = new Date().toISOString().split('T')[0];
  var weekAgo = new Date(Date.now() - 7 * 86400000).toISOString().split('T')[0];
  var results = { nudgeType: nudgeType, sent: 0, failed: 0, skipped: 0 };

  var subsResult = await supabase.from('push_subscriptions').select('user_id, endpoint, keys, peak_hour');
  var subs = subsResult.data;
  if (!subs || !subs.length) return results;

  for (var i = 0; i < subs.length; i++) {
    var sub = subs[i];
    try {
      var userData       = await supabase.from('users').select('name, streak, coins').eq('id', sub.user_id).single();
      var habitsData     = await supabase.from('habits').select('id, name, icon, target_type, daily_target').eq('user_id', sub.user_id);
      var goalsData      = await supabase.from('goals').select('title, progress, status, deadline, category').eq('user_id', sub.user_id).eq('status', 'active');
      var onboardingData = await supabase.from('onboarding').select('*').eq('user_id', sub.user_id).single();
      var logsToday      = await supabase.from('habit_logs').select('habit_id, completed').eq('user_id', sub.user_id).eq('date', today);
      var logsWeek       = await supabase.from('habit_logs').select('habit_id, completed, date').eq('user_id', sub.user_id).gte('date', weekAgo);

      var doneIds = {};
      if (logsToday.data) {
        logsToday.data.filter(function(l) { return l.completed; }).forEach(function(l) { doneIds[l.habit_id] = true; });
      }
      var habits = (habitsData.data || []).map(function(h) {
        return Object.assign({}, h, { done: !!doneIds[h.id] });
      });
      var weeklyHabits = buildWeeklyRates(habitsData.data || [], logsWeek.data || []);

      var doneCount = habits.filter(function(h) { return h.done; }).length;
      var pct = habits.length > 0 ? Math.round(doneCount / habits.length * 100) : 0;

      if (nudgeType === 'danger' && pct > 0) { results.skipped++; continue; }
      if (nudgeType === 'midday' && pct >= 50) { results.skipped++; continue; }

      var payload = engine.buildNudge(
        nudgeType,
        userData.data || {},
        onboardingData.data || {},
        habits,
        goalsData.data || [],
        weeklyHabits
      );

      if (!payload) { results.skipped++; continue; }
      payload.url = '/';

      await webpush.sendNotification(
        { endpoint: sub.endpoint, keys: sub.keys },
        JSON.stringify(payload)
      );
      results.sent++;
    } catch (err) {
      if (err.statusCode === 410) {
        await supabase.from('push_subscriptions').delete().eq('user_id', sub.user_id);
      }
      results.failed++;
      console.error('[Luhv+] Push failed user ' + sub.user_id + ': ' + err.message);
    }
  }
  console.log('[Luhv+] Nudge done: ' + JSON.stringify(results));
  return results;
}

function buildWeeklyRates(habits, weekLogs) {
  return habits.map(function(habit) {
    var logs = weekLogs.filter(function(l) { return l.habit_id === habit.id; });
    var completed = logs.filter(function(l) { return l.completed; }).length;
    return Object.assign({}, habit, { completedDays: completed, totalDays: 7, rate: Math.round((completed / 7) * 100) });
  });
}

module.exports = router;
